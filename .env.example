# ---- Database (Neon recommended) ----
# Pooled connection (for serverless app code)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/pitchflare?sslmode=require"
# Direct connection (for Prisma migrations)
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/pitchflare?sslmode=require"

# ---- Clerk (auth + organizations) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-xxx
# Optional model overrides
CLAUDE_MODEL_OPUS=claude-opus-4-7
CLAUDE_MODEL_SONNET=claude-sonnet-4-6
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_SOLO_MONTHLY=price_xxx
STRIPE_PRICE_SOLO_YEARLY=price_xxx
STRIPE_PRICE_BOUTIQUE_MONTHLY=price_xxx
STRIPE_PRICE_BOUTIQUE_YEARLY=price_xxx
STRIPE_PRICE_AGENCY_MONTHLY=price_xxx
STRIPE_PRICE_AGENCY_YEARLY=price_xxx

# ---- Resend (transactional + campaign fallback) ----
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="PitchFlare <notifications@pitchflare.com>"

# ---- Inngest ----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Encryption (AES-256-GCM for data-partner API keys) ----
# 32-byte key, base64-encoded. Generate with: openssl rand -base64 32
PF_ENCRYPTION_KEY=

# ---- Monitoring sources ----
BING_NEWS_API_KEY=
GDELT_ENABLED=true

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Observability ----
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
